# MomOps Configuration

AWS_ACCESS_KEY_ID=AKIA...
AWS_SECRET_ACCESS_KEY=...
AWS_SESSION_TOKEN=        # Optional, for temporary credentials
AWS_DEFAULT_REGION=us-east-1
ANTHROPIC_API_KEY=sk-ant-...
MOMOPS_BUDGET_LIMIT=1000

MOMOPS_DRY_RUN=false

MOMOPS_LOG_LEVEL=INFO
MOMOPS_JSON_LOGGING=false

MOMOPS_STATE_DIR=~/.momops
MOMOPS_DEPLOYMENT_TIMEOUT=1800

MOMOPS_PRICING_MODE=static


# Optional: Stripe (if using paid plans)

# STRIPE_API_KEY=sk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# Optional: Datadog Monitoring (for production)

# DATADOG_API_KEY=...
# DATADOG_APP_KEY=...

# For testing with moto (AWS mocking)
# MOTO_MOCK=true



